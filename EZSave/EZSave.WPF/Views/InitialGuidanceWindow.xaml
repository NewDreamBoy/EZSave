<Window
    x:Class="EZSave.WPF.Views.InitialGuidanceWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:EZSave.WPF.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utilities="clr-namespace:EZSave.WPF.Utilities.AttachedProperties"
    Title="引导"
    Width="1024"
    Height="600"
    utilities:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">
    <Grid>
        <StackPanel>
            <TextBlock Text="{Binding Title}" />
            <Button Width="130" Height="40" Margin="5" Command="{Binding AddPlanCommand}" />
        </StackPanel>
    </Grid>
</Window>
